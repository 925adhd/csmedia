# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Claude Code local files (settings, screenshots, agent scripts)
.claude/

# Supabase CLI working dir
supabase/.temp/

# OS metadata
**/desktop.ini
**/Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# live database reference (contains project URLs)
supabase/LIVE-DATABASE.md

# SEO audit docs
GOLDEN_GOOGLE_SEO_AUDIT*

# local-only reference assets (source material, logo iterations, screenshots)
/assets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
